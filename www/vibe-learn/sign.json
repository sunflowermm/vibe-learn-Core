{
  "id": "vibe-learn",
  "name": "Vibe Learn — 知识节点图谱",
  "enabled": false,
  "serve": "static",
  "staticRoot": "dist",
  "build": { "command": "pnpm", "args": ["build"] },
  "_note": "enabled=false：只 build 不启进程，挂 dist。HMR：enabled=true + serve=proxy。",
  "command": "pnpm",
  "args": ["dev"],
  "port": 5188,
  "proxy": { "mount": "/vibe-learn" },
  "env": { "BROWSER": "none" },
  "autoRestart": true
}

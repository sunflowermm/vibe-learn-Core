{
  "id": "vibe-learn",
  "name": "Vibe Learn — 知识节点图谱",
  "enabled": false,
  "serve": "static",
  "staticRoot": "dist",
  "_note": "静态托管 dist/。HMR：serve 改 proxy、enabled 改 true，重启主服。",
  "mode": "dev",
  "command": "pnpm",
  "args": ["dev"],
  "devOnly": true,
  "modes": ["dev"],
  "port": 5188,
  "proxy": { "mount": "/vibe-learn" },
  "env": { "BROWSER": "none" },
  "autoRestart": true
}
